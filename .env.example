# Copiá este archivo a .env.local y completá los valores.
# Todas las vars NEXT_PUBLIC_* se exponen al browser — NUNCA pongas acá la
# service_role key de Supabase ni ningún secreto de servidor.

# Supabase (la publishable key es browser-safe → NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# insyta-api base URL (FastAPI). Local: 8000 (uvicorn). Prod: la URL de Railway.
NEXT_PUBLIC_API_URL=http://localhost:8000
